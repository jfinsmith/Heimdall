# ─── HEIMDALL frontend (Vite) ────────────────────────────────────────────────
# Copy to `.env` for local dev. For GitHub Pages deploys, set these same keys
# as GitHub Actions secrets (see README → "GitHub Pages deploy").
# These come from Firebase Console → Project settings → Your apps → Web app.
# They are public client config, not secrets — but keep .env out of git anyway.

# TODO(setup): paste your Firebase web app config values
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Seed script / Option B cron (Admin SDK, server-side only) ───────────────
# TODO(setup): path to a service-account JSON you download from
# Firebase Console → Project settings → Service accounts → Generate new private key.
# For the Option B GitHub Actions cron, store the JSON *content* in the
# FIREBASE_SERVICE_ACCOUNT secret instead.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ─── Option B email transport (only if NOT using the Trigger Email extension) ─
# TODO(setup): any SMTP-provider HTTP API key (SendGrid shown; see scripts/gjallarhorn-cron.ts)
SENDGRID_API_KEY=
MAIL_FROM="HEIMDALL <no-reply@example.org>"
