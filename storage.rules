rules_version = '2';

// HEIMDALL Cloud Storage rules. Role is carried on the auth custom claim
// (request.auth.token.role), same as Firestore rules. ADMIN_ROLES = director,
// lieutenant ([[lieutenant-equals-director]]).
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() { return request.auth != null; }
    function isAdmin() {
      return signedIn() && request.auth.token.role in ['director', 'lieutenant'];
    }
    function isStaff() {
      return signedIn() && request.auth.token.role in ['director', 'lieutenant', 'sergeant', 'coordinator'];
    }

    // Bug / feature report screenshots, partitioned by tenant: feedback/{orgId}/{uid}/…
    // The uploader writes under their own uid; reads are scoped to a SAME-TENANT
    // admin (orgId path segment == the admin's org claim) or the owner. This
    // prevents an admin in one college from reading another college's report
    // images. Images only, ≤ 10 MB.
    match /feedback/{orgId}/{uid}/{allPaths=**} {
      allow read: if (isAdmin() && orgId == request.auth.token.get('orgId', null))
        || (signedIn() && request.auth.uid == uid);
      allow write: if signedIn()
        && request.auth.uid == uid
        && orgId == request.auth.token.get('orgId', null)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if (isAdmin() && orgId == request.auth.token.get('orgId', null))
        || (signedIn() && request.auth.uid == uid);
    }

    // Per-org logo (branding). Public read — a logo is a non-sensitive brand
    // asset shown in-app, on printed documents, and in outbound email (to
    // recipients who may not be signed in). Only that org's admin may upload it.
    match /branding/{orgId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin()
        && orgId == request.auth.token.get('orgId', null)
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Room diagrams / floor plans, partitioned by tenant: rooms/{orgId}/…
    // Schedule-building staff (who manage rooms) may upload; read is limited to
    // signed-in members (a floor plan is org-internal, unlike a public logo).
    match /rooms/{orgId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if isStaff()
        && orgId == request.auth.token.get('orgId', null)
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if isStaff() && orgId == request.auth.token.get('orgId', null);
    }

    // Everything else: locked down by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
