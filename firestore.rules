rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// HEIMDALL Firestore security rules — enforces the §4 RBAC matrix AND pooled
// multi-tenant isolation (Phase 5 cutover).
//
// Roles ride on a custom auth claim (request.auth.token.role); the tenant rides
// on request.auth.token.orgId (minted by the admin callables + the org backfill).
// Chain of command: instructor → coordinator → sergeant → lieutenant → director.
//
// TENANT ISOLATION: every org-owned doc carries an `orgId` field, and a caller
// may only touch docs whose orgId matches their own claim (inOrg). Reads/lists
// therefore REQUIRE the client query to be orgId-constrained (centralized in
// useCollection); creates must stamp the caller's orgId; orgId is immutable on
// update. A caller whose token lacks an orgId claim matches nothing — the
// AuthContext force-refresh mints the claim into the live token at sign-in so a
// freshly-backfilled session isn't locked out.
//
// Known rules-language limits, mitigated in code:
//  • roleSlots[].filledBy.length <= count — enforced in the sign-up transaction.
//  • qualifications[].verified (array of maps) — gated via the flat
//    verifiedQualKeys array, which self-edits must keep unchanged.
// ─────────────────────────────────────────────────────────────────────────────
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }
    function role() {
      return signedIn() && 'role' in request.auth.token ? request.auth.token.role : 'instructor';
    }
    // Coordinator and above: may build schedules, approve sign-ups, verify quals.
    function isStaff() {
      return signedIn() && role() in ['director', 'lieutenant', 'sergeant', 'coordinator'];
    }
    // Command: may manage users, roles, and org settings.
    function isAdmin() {
      return signedIn() && role() in ['director', 'lieutenant'];
    }
    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }
    function unchanged(field) {
      return request.resource.data.get(field, null) == resource.data.get(field, null);
    }
    // ── Tenant helpers ──────────────────────────────────────────────────────
    // The caller's tenant from their custom claim (null if unsigned/unassigned).
    function tokenOrgId() {
      return signedIn() ? request.auth.token.get('orgId', null) : null;
    }
    function isPlatformOwner() {
      return signedIn() && request.auth.token.get('platformOwner', false) == true;
    }
    // A doc belongs to the caller's tenant. Requires the caller to HAVE an org
    // claim, so an orgless/stale token can't read orgless docs as a back door.
    function inOrg(data) {
      return tokenOrgId() != null && data.get('orgId', null) == tokenOrgId();
    }
    // A class may be published only after the captain's approval. Templates are
    // exempt. (Repeated get() on the same path is cached → one read.)
    function academyOkToPublish(aid) {
      return get(/databases/$(database)/documents/academies/$(aid)).data.get('isTemplate', false) == true
          || get(/databases/$(database)/documents/academies/$(aid)).data.get(['approval', 'state'], '') == 'approved';
    }

    // ── orgs (tenant registry) ───────────────────────────────────────────────
    // Read your own org; the platform owner reads all (owner console). Writes are
    // the createOrg callable (Admin SDK) only.
    match /orgs/{orgId} {
      allow read: if signedIn() && (orgId == tokenOrgId() || isPlatformOwner());
      allow write: if false;
    }

    // ── users ──────────────────────────────────────────────────────────────
    // Own doc: read + create + limited update. Staff read/manage SAME-TENANT
    // users only. role / status / verifiedQualKeys are admin-or-staff-set; orgId
    // / platformOwner are server-managed (Admin SDK). A freshly self-registered
    // user has no orgId yet and is reachable only by themselves until an admin
    // assigns a role (setUserRole stamps the admin's org); surfacing such pending
    // cross-org registrations to the right admin is Phase-6 (multi-tenant sign-in).
    match /users/{uid} {
      allow read: if isOwner(uid) || (isStaff() && inOrg(resource.data));
      allow create: if isOwner(uid)
        && request.resource.data.role == 'instructor'
        && request.resource.data.status == 'pending'
        && request.resource.data.verifiedQualKeys == []
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && request.resource.data.qualifications is list
        // Tenant + platform claims are server-managed (Admin SDK only) — never
        // self-set, or a self-registrant could pre-seed platformOwner:true and
        // have it minted into a real claim on their first role assignment.
        && !('orgId' in request.resource.data)
        && !('platformOwner' in request.resource.data);
      // orgId / platformOwner / homeOrgId / homeRole are ONLY written by the Admin
      // SDK (callables + scripts), which bypass these rules. No client update — not
      // even an admin — may change them; the role-minting + owner-switch callables
      // trust the user doc (homeOrgId/homeRole anchor the owner's reversible switch).
      allow update: if unchanged('orgId') && unchanged('platformOwner')
        && unchanged('homeOrgId') && unchanged('homeRole') && (
        (isAdmin() && inOrg(resource.data))
        // Staff (coordinator/sergeant) may approve accounts and verify quals on
        // OTHER same-tenant users, but may not change roles, and may NOT
        // self-grant their own status / verifiedQualKeys (no self-escalation).
        || (isStaff()
            && inOrg(resource.data)
            && unchanged('role')
            && (request.auth.uid != uid || (unchanged('status') && unchanged('verifiedQualKeys'))))
        // Self-service: profile fields only.
        || (isOwner(uid)
            && unchanged('role')
            && unchanged('status')
            && unchanged('verifiedQualKeys')
            && unchanged('email')));
      allow delete: if isAdmin() && inOrg(resource.data);
    }

    // ── settings/{orgId} (per-tenant config; doc id == orgId) ────────────────
    // Read/write ONLY your own org's settings doc. (The legacy 'global' doc is no
    // longer client-readable post-cutover; the Admin SDK still reads it server-side.)
    match /settings/{docId} {
      allow read: if signedIn() && docId == tokenOrgId();
      allow write: if isAdmin() && docId == tokenOrgId();
    }

    // ── reportConfig/{orgId} (per-tenant report categories + name overrides) ─
    match /reportConfig/{docId} {
      allow read: if signedIn() && docId == tokenOrgId();
      allow write: if isAdmin() && docId == tokenOrgId();
    }

    // ── feedbackReports (member-submitted bug / feature reports) ────────────
    // A member files their own (stamped with their org); same-org admins triage.
    // (Cross-org owner visibility is a later phase.)
    match /feedbackReports/{id} {
      allow read: if (isAdmin() && inOrg(resource.data)) || isOwner(resource.data.submittedByUid);
      allow create: if signedIn()
        && request.resource.data.submittedByUid == request.auth.uid
        && inOrg(request.resource.data)
        && request.resource.data.status == 'new'
        && request.resource.data.kind in ['bug', 'feature']
        && request.resource.data.title is string
        && request.resource.data.description is string;
      allow update, delete: if isAdmin() && inOrg(resource.data);
    }

    // ── courseCatalog ──────────────────────────────────────────────────────
    match /courseCatalog/{courseId} {
      allow read: if signedIn() && inOrg(resource.data);
      allow create: if isStaff() && inOrg(request.resource.data);
      allow update: if isStaff() && inOrg(resource.data) && unchanged('orgId');
      allow delete: if isStaff() && inOrg(resource.data);
    }

    // ── curricula (admin-editable disciplines + minimum hours) ─────────────
    match /curricula/{key} {
      allow read: if signedIn() && inOrg(resource.data);
      allow create: if isAdmin() && inOrg(request.resource.data);
      allow update: if isAdmin() && inOrg(resource.data) && unchanged('orgId');
      allow delete: if isAdmin() && inOrg(resource.data);
    }

    // ── room reservation: categories + rooms (org-scoped) ─────────────────
    // Schedule-building staff manage them; any signed-in member of the org may
    // read (room pickers + the reservation calendar). orgId is immutable.
    match /roomCategories/{id} {
      allow read: if signedIn() && inOrg(resource.data);
      allow create: if isStaff() && inOrg(request.resource.data);
      allow update: if isStaff() && inOrg(resource.data) && unchanged('orgId');
      allow delete: if isStaff() && inOrg(resource.data);
    }
    match /rooms/{id} {
      allow read: if signedIn() && inOrg(resource.data);
      allow create: if isStaff() && inOrg(request.resource.data);
      allow update: if isStaff() && inOrg(resource.data) && unchanged('orgId');
      allow delete: if isStaff() && inOrg(resource.data);
    }

    // ── defaultCurricula (platform-level templates new orgs seed from) ─────
    // No orgId — these belong to the platform, not a tenant. Owner-only.
    match /defaultCurricula/{key} {
      allow read, write: if isPlatformOwner();
    }

    // ── documentLibrary (owner-managed forms library) ─────────────────────
    // General forms are readable by any org's staff; specialized forms only by an
    // assigned org. NOT tenant-scoped — only the platform owner may write.
    match /documentLibrary/{id} {
      // The specialized branch uses the canonical array-membership form
      // (`<authValue> in resource.data.field`) directly — not via tokenOrgId() or an
      // `is list` guard — so Firestore can prove the array-contains LIST query safe.
      allow read: if isPlatformOwner()
        || (isStaff() && (resource.data.availability == 'general'
            || request.auth.token.orgId in resource.data.orgIds));
      allow write: if isPlatformOwner();
    }

    // ── documentForms (in-app document builder, Phase 12) ──────────────────
    // Org-scoped admin/owner-authored documents; staff read them to file reports.
    // Writers must be command (or the platform owner) AND in the doc's org — so an
    // owner can only author for the org they're currently switched into.
    match /documentForms/{id} {
      allow read: if (isStaff() || isPlatformOwner()) && inOrg(resource.data);
      allow create: if (isAdmin() || isPlatformOwner()) && inOrg(request.resource.data);
      allow update: if (isAdmin() || isPlatformOwner()) && inOrg(resource.data) && unchanged('orgId');
      allow delete: if (isAdmin() || isPlatformOwner()) && inOrg(resource.data);
    }

    // ── coursePublishEvents ────────────────────────────────────────────────
    match /coursePublishEvents/{id} {
      allow read: if isStaff() && inOrg(resource.data);
      allow create: if isStaff()
        && request.resource.data.requestedBy == request.auth.uid
        && inOrg(request.resource.data);
      allow update, delete: if false;
    }

    // ── academies ──────────────────────────────────────────────────────────
    // Instructors see published lifecycle states only; staff see everything —
    // both within their own tenant. Lists MUST be orgId-constrained (useCollection).
    match /academies/{academyId} {
      allow read: if inOrg(resource.data) && (
        isStaff()
        || (signedIn() && resource.data.status in ['published', 'in_progress', 'completed'])
      );
      allow create: if isStaff() && inOrg(request.resource.data);
      allow delete: if isStaff() && inOrg(resource.data);
      // Staff edit freely within their org, EXCEPT moving into a published
      // lifecycle state, which requires the captain's approval (templates exempt).
      // orgId is immutable. Approval transitions are written by the academyApproval
      // callable (Admin SDK).
      allow update: if isStaff() && inOrg(resource.data) && unchanged('orgId') && (
        !(request.resource.data.status in ['published', 'in_progress', 'completed'])
        || resource.data.status in ['published', 'in_progress', 'completed']
        || request.resource.data.get('isTemplate', false) == true
        || request.resource.data.get(['approval', 'state'], '') == 'approved'
      );

      // ── roster (per-academy cadets) ──────────────────────────────────────
      // Same-tenant staff only — holds PII. Encrypted SSN fields are owned by the
      // roster callables (Admin SDK); a client write may not set/alter them.
      match /roster/{memberId} {
        allow read: if isStaff() && inOrg(resource.data);
        allow create: if isStaff()
          && inOrg(request.resource.data)
          && !('ssnCipher' in request.resource.data)
          && !('ssnLast4' in request.resource.data);
        allow delete: if isStaff() && inOrg(resource.data);
        allow update: if isStaff()
          && inOrg(resource.data)
          && unchanged('orgId')
          && request.resource.data.get('ssnCipher', '') == resource.data.get('ssnCipher', '')
          && request.resource.data.get('ssnLast4', '') == resource.data.get('ssnLast4', '');
      }

      // ── academic-action reports (cadet exam-failure / dismissal letters) ──
      match /reports/{reportId} {
        allow read: if isStaff() && inOrg(resource.data);
        allow create: if isStaff() && inOrg(request.resource.data);
        allow update: if isStaff() && inOrg(resource.data) && unchanged('orgId');
        allow delete: if isStaff() && inOrg(resource.data);
      }
    }

    // ── sessions ───────────────────────────────────────────────────────────
    match /sessions/{sessionId} {
      allow read: if inOrg(resource.data) && (isStaff() || (signedIn() && resource.data.status != 'draft'));
      // New sessions must be draft unless the parent academy is approved/template
      // (so a session can't be created already-visible to dodge approval).
      allow create: if isStaff()
        && inOrg(request.resource.data)
        && request.resource.data.roleSlots is list
        && (request.resource.data.status == 'draft' || academyOkToPublish(request.resource.data.academyId));
      // NOTE: delete is separate — on delete there is no request.resource.
      allow delete: if isStaff() && inOrg(resource.data);
      // Staff edit freely within their org, EXCEPT flipping draft→visible
      // (publishing), which requires the parent academy's approval. orgId is
      // immutable. Non-staff updates exist only for the sign-up transaction: they
      // may touch ONLY roleSlots / status / updatedAt, may not invent new slots,
      // and the count math is enforced in the transaction.
      allow update: if (isStaff() && inOrg(resource.data) && unchanged('orgId') && (
            request.resource.data.status == resource.data.status
            || request.resource.data.status == 'draft'
            || resource.data.status != 'draft'
            || academyOkToPublish(resource.data.academyId)
          ))
        || (signedIn()
            && inOrg(resource.data)
            && unchanged('orgId')
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['roleSlots', 'status', 'updatedAt'])
            && request.resource.data.roleSlots.size() == resource.data.roleSlots.size()
            && request.resource.data.status in ['open', 'fully_staffed']);

      // ── signups subcollection ────────────────────────────────────────────
      // Same-tenant. A user manages only their own signup doc; staff write any.
      match /signups/{uid} {
        allow read: if signedIn() && inOrg(resource.data);
        allow create: if (isStaff() && inOrg(request.resource.data))
          || (isOwner(uid)
              && request.resource.data.uid == uid
              && inOrg(request.resource.data)
              && request.resource.data.status in ['confirmed', 'waitlist']
              && get(/databases/$(database)/documents/users/$(uid)).data.status == 'active');
        allow update: if (isStaff() && inOrg(resource.data))
          || (isOwner(uid) && inOrg(resource.data) && request.resource.data.status in ['confirmed', 'waitlist', 'withdrawn']);
        allow delete: if isStaff() && inOrg(resource.data);
      }
    }

    // ── assignments ────────────────────────────────────────────────────────
    // Denormalized mirror. Readable by owner + staff, within tenant. Written by
    // the sign-up transaction (owner, own uid) and Cloud Functions (Admin SDK).
    match /assignments/{assignmentId} {
      allow read: if inOrg(resource.data) && (isStaff() || resource.data.uid == request.auth.uid);
      allow create: if inOrg(request.resource.data)
        && (isStaff() || request.resource.data.uid == request.auth.uid);
      allow update: if (isStaff() && inOrg(resource.data) && unchanged('orgId'))
        || (signedIn()
            && inOrg(resource.data)
            && unchanged('orgId')
            && resource.data.uid == request.auth.uid
            && request.resource.data.uid == request.auth.uid);
      allow delete: if isStaff() && inOrg(resource.data);
    }

    // ── notifications ──────────────────────────────────────────────────────
    // Per-recipient (uid is the scope; a user belongs to one tenant). Function-
    // written; owner may read and mark read.
    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if false; // Gjallarhorn (Admin SDK) only
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // ── mail ───────────────────────────────────────────────────────────────
    // Watched by the Trigger Email extension. Server-written ONLY; same-tenant
    // admin read (notify() stamps orgId on each mail doc).
    match /mail/{mailId} {
      allow read: if isAdmin() && inOrg(resource.data);
      allow write: if false; // functions/Admin SDK only
    }

    // ── bulkMessages ───────────────────────────────────────────────────────
    match /bulkMessages/{id} {
      allow read: if isStaff() && inOrg(resource.data);
      allow create: if isStaff()
        && request.resource.data.requestedBy == request.auth.uid
        && inOrg(request.resource.data)
        && request.resource.data.status == 'pending';
      allow update, delete: if false;
    }

    // ── auditLog ───────────────────────────────────────────────────────────
    // Append-only from clients (must stamp own uid + own org); same-tenant admin read.
    match /auditLog/{logId} {
      allow read: if isAdmin() && inOrg(resource.data);
      allow create: if signedIn()
        && request.resource.data.actorUid == request.auth.uid
        && inOrg(request.resource.data);
      allow update, delete: if false;
    }

    // Default deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
